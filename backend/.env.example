# .env.example
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ENVIRONMENT=local            # local | staging | production
DEBUG=true                   # Must be false in production (enforced by Settings)
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ---------------------------------------------------------------------------
# Database (PostgreSQL 16)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ams_user:ams_pass@localhost:5432/ams_db
TEST_DATABASE_URL=postgresql+asyncpg://ams_user:ams_pass@localhost:5432/ams_test_db

# ---------------------------------------------------------------------------
# Cache (Redis 7)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Auth / Security
# ---------------------------------------------------------------------------
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-32-byte-hex-secret-before-deploying
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Default system admin created on startup
DEFAULT_ADMIN_EMAIL=admin@ams.edu
DEFAULT_ADMIN_PASSWORD=TestPass123!

# ---------------------------------------------------------------------------
# CORS & Trusted Hosts
# ---------------------------------------------------------------------------
# Comma-separated list; never use "*" in production
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# ---------------------------------------------------------------------------
# OpenTelemetry (OTLP HTTP)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ams-api

# ---------------------------------------------------------------------------
# Gunicorn / Uvicorn (production)
# ---------------------------------------------------------------------------
PORT=8000
WEB_CONCURRENCY=4

# ---------------------------------------------------------------------------
# Object Storage (S3-compatible)
# ---------------------------------------------------------------------------
# This system works with any S3-compatible provider.
# Set the variables below for your chosen provider.
#
# Variable                  AWS SDK equivalent          Notes
# ──────────────────────────────────────────────────────────────────────────
# STORAGE_ACCESS_KEY        AWS_ACCESS_KEY_ID           MinIO root user / AWS key
# STORAGE_SECRET_KEY        AWS_SECRET_ACCESS_KEY       MinIO root pass / AWS secret
# STORAGE_ENDPOINT_URL      endpoint_url kwarg          Omit (blank) for real AWS S3
# STORAGE_REGION            AWS_DEFAULT_REGION          Dummy value ok for MinIO / R2
# ──────────────────────────────────────────────────────────────────────────
#
# MinIO (local dev / self-hosted):
#   STORAGE_ENDPOINT_URL=http://localhost:9000      ← use http://minio:9000 inside Docker
#   STORAGE_ACCESS_KEY=ams_minio_user
#   STORAGE_SECRET_KEY=ams_minio_pass
#
# AWS S3 (production):
#   STORAGE_ENDPOINT_URL=                          ← leave blank; SDK auto-routes to AWS
#   STORAGE_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
#   STORAGE_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
#   STORAGE_REGION=eu-west-1
#
# Cloudflare R2:
#   STORAGE_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
#   STORAGE_ACCESS_KEY=<r2_access_key_id>
#   STORAGE_SECRET_KEY=<r2_secret_access_key>
#   STORAGE_REGION=auto
#
STORAGE_ENDPOINT_URL=http://localhost:9000
# Public-facing URL for storage — what browsers/clients use to download files.
# When running inside Docker:
#   STORAGE_ENDPOINT_URL=http://minio:9000       (set in docker-compose override)
#   STORAGE_PUBLIC_URL=http://localhost:9000     (stays from .env; browser reaches this)
# For AWS S3 / R2: leave blank — presigned URLs are self-contained.
STORAGE_PUBLIC_URL=http://localhost:9000
STORAGE_ACCESS_KEY=change-me-access-key
STORAGE_SECRET_KEY=change-me-secret-key
STORAGE_BUCKET_NAME=ams-storage-bucket
STORAGE_REGION=us-east-1

# Download URL mode:
#   false  = plain public URL (bucket must have public-read; good for dev)
#   true   = time-limited presigned URL (no public access needed; recommended for prod)
STORAGE_PRESIGNED_DOWNLOADS=false
STORAGE_PRESIGNED_EXPIRY_SECONDS=3600
